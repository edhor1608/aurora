{
  "name": "aurora",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": ["apps/*", "packages/*", "convex"],
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "quality": "bun run scripts/quality/check-repo.ts",
    "verify": "bun run typecheck && bun run lint && bun run quality && bun run test && bun run test:e2e:browser:local",
    "test": "vitest run",
    "test:e2e:browser": "playwright test",
    "test:e2e:browser:local": "bun run scripts/run-browser-e2e-if-env.ts",
    "test:e2e:browser:headed": "playwright test --headed"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "^1.55.1",
    "@types/node": "^22.19.11",
    "convex-test": "^0.0.51",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "convex": "^1.32.0"
  }
}
