{
  "name": "aurora",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*",
    "convex"
  ],
  "scripts": {
    "typecheck": "turbo run typecheck",
    "typecheck:tsc": "turbo run typecheck:tsc",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:workspaces": "turbo run test --filter=@aurora/*",
    "test:smoke": "turbo run test:smoke",
    "test:e2e:browser": "playwright test",
    "test:e2e:browser:headed": "playwright test --headed"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.55.1",
    "@types/node": "^22.19.11",
    "@typescript/native-preview": "7.0.0-dev.20260321.1",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "convex": "^1.32.0"
  }
}
